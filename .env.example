# ============================================================
#  நல்ல நேரம் Pro — environment variables
#  Copy to `.env.local` for local dev, and add each one in the Vercel
#  dashboard (Project → Settings → Environment Variables) for production.
#  NEVER commit real values. Only the two marked PUBLIC are safe in the browser.
# ============================================================

# ---- Public site ----
PUBLIC_SITE_URL=https://nallaneram.com

# ---- Clerk (auth) ----
# Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx     # PUBLIC (goes in NN_CONFIG)
CLERK_SECRET_KEY=sk_live_xxx                       # SERVER ONLY

# ---- Supabase (database) ----
# Project → Settings → API
SUPABASE_URL=https://xxxx.supabase.co              # PUBLIC (goes in NN_CONFIG)
SUPABASE_ANON_KEY=eyJhbGci...                      # PUBLIC (goes in NN_CONFIG)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...              # SERVER ONLY — bypasses RLS, guard it

# ---- Stripe (payments) ----
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxx                       # SERVER ONLY
STRIPE_WEBHOOK_SECRET=whsec_xxx                     # SERVER ONLY (from the webhook endpoint)
STRIPE_PRICE_ID=price_xxx                           # the CA$9.99/yr recurring price
